# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# Node environment
NODE_ENV=production

# Yandex Disk OAuth Token (если используется)
YANDEX_DISK_TOKEN=your_yandex_disk_token_here

# Yandex Maps API Key (для карты точек продаж)
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your_yandex_maps_api_key

# MariaDB (индекс товаров и файлов; значения из ISPmanager)
DATABASE_URL=mysql://user:password@host:3306/database

# Admin credentials (измените на свои!)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_secure_password_here

# JWT Secret (сгенерируйте случайную строку)
JWT_SECRET=your_random_jwt_secret_at_least_32_chars

# FTP credentials (если используется)
FTP_HOST=ftp.example.com
FTP_USER=ftp_username
FTP_PASSWORD=ftp_password

# Импорт разрешительной документации (npm run import:permit-documents)
# PERMIT_REGISTRY_PATH=/abs/path/Разрешительная документация.xlsx
# PERMIT_DOCUMENTS_ROOT=/abs/path/каталог_с_pdf_и_doc_рядом_с_excel
